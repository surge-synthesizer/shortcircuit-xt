{
  "name": "GeneralUser-GS GrandPiano — C major chord loop",
  "description": "Loads only the GrandPiano preset from GeneralUser-GS and loops a C major chord (C-E-G-C).",
  "engine": {
    "sample_rate": 48000.0
  },
  "load": [
    {
      "kind": "load_instrument",
      "path": "/Users/paul/Music/Samples/SCTests/GeneralUser-GS/GeneralUser-GS.sf2",
      "preset_name": "Grand Piano"
    }
  ],
  "sequence": {
    "preset": "c_major_chord",
