{
  "name": "BadPluck WAV — C major chord × 5",
  "description": "Polyphony test using the bundled BadPluckSample.wav.",
  "engine": {
    "sample_rate": 48000.0
  },
  "load": [
    {
      "kind": "load_instrument",
      "path": "resources/test_samples/BadPluckSample.wav"
    }
  ],
  "sequence": {
    "preset": "c_major_chord",
    "params": {
      "note_len_s": 0.5,
      "gap_s": 0.3,
      "repeats": 5,
      "velocity": 100,
      "chord_keys": [60, 64, 67, 72]
    }
  },
  "run": {
    "mode": "measure",
    "warmup_iterations": 1,
    "measure_iterations": 3,
    "tail_silence_s": 0.5,
    "report_path": "/tmp/perf_chord.json"
  }
}
